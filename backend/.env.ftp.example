# FTP Configuration
# ==================

# Serveur FTP
FTP_HOST=localhost
FTP_PORT=21
FTP_USER=ftpuser
FTP_PASSWORD=ftppassword
FTP_SECURE=false

# Répertoire FTP pour les avatars (sur le serveur FTP)
FTP_AVATAR_DIR=/uploads/avatars

# Exemple avec un serveur FTP sécurisé (FTPS):
# FTP_HOST=ftp.example.com
# FTP_PORT=21
# FTP_USER=myuser
# FTP_PASSWORD=mypassword
# FTP_SECURE=true
# FTP_AVATAR_DIR=/home/user/uploads/avatars

# Exemple de test local avec vsftpd:
# FTP_HOST=127.0.0.1
# FTP_PORT=21
# FTP_USER=testuser
# FTP_PASSWORD=testpass
# FTP_SECURE=false
# FTP_AVATAR_DIR=/home/testuser/uploads
