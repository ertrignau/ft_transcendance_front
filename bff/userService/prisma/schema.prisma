generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  firstName String
  lastName  String
  avatar    String?
  bio       String?
  theme     Theme    @default(LIGHT)
  langue    String   @default("en")
  createdAt DateTime @default(now())
}

enum Theme {
  LIGHT
  DARK
}